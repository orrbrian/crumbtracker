{
  "name": "crumbtracker",
  "version": "0.9.4",
  "description": "Local calorie and nutrition tracker",
  "main": "main.js",
  "author": "CrumbTracker",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@zxing/browser": "^0.1.5",
    "electron-updater": "^6.8.3",
    "pica": "^9.0.1",
    "qrcode": "^1.5.4",
    "selfsigned": "^5.5.0",
    "tesseract.js": "^7.0.0"
  },
  "build": {
    "appId": "com.crumbtracker.app",
    "productName": "CrumbTracker",
    "files": [
      "main.js",
      "preload.js",
      "remote-scanner.js",
      "renderer/**/*",
      "package.json",
      "!**/*.map"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "renderer/assets/icon.png",
      "signtoolOptions": {
        "certificateSubjectName": "Open Source Developer Brian Orr",
        "signingHashAlgorithms": [
          "sha256"
        ]
      },
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "CrumbTracker"
    },
    "portable": {
      "artifactName": "CrumbTracker-${version}-portable.exe"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "orrbrian",
        "repo": "crumbtracker"
      }
    ]
  }
}
